{
  "expo": {
    "name": "Tarek Wisper",
    "owner": "altitudeinfosys",
    "slug": "tarek-wisper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tarekalaaddin.tarekwisper",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tarekalaaddin.tarekwisper",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F8FAFC"
      }
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Tarek Wisper to use the microphone for transcription and translation recordings.",
          "recordAudioAndroid": true
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "146688ee-d90f-4ee9-8107-7633a1168c04"
      }
    }
  }
}
